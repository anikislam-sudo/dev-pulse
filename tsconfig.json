{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",

    "module": "CommonJS",
    "target": "ES2020",

    "moduleResolution": "node",

    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,

    "strict": true,

    "types": ["node"],

    "skipLibCheck": true,

    "sourceMap": true,

    "ignoreDeprecations": "6.0"
  },

  "include": ["src/**/*"]
}
